/* pages/statistics/statistics.wxss - iOS深色星空风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #0a0e27 0%, #1a1f3d 50%, #0f1429 100%);
  min-height: 100vh;
  position: relative;
}

.overview-card {
  background: rgba(30, 35, 60, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.overview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 30rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.overview-item {
  background: rgba(255, 255, 255, 0.05);
  padding: 30rpx;
  border-radius: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #007AFF;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 10rpx;
}

.streak-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 122, 255, 0.4);
}

.streak-icon {
  font-size: 64rpx;
  margin-right: 30rpx;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.3));
}

.streak-info {
  text-align: center;
  flex: 1;
}

.streak-value {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
}

.streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

.streak-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 40rpx;
}

.period-stats {
  background: rgba(30, 35, 60, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.period-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  transition: all 0.3s;
}

.period-tab.active {
  background: linear-gradient(135deg, #007AFF, #5856D6);
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

.period-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.period-fill {
  height: 100%;
  background: linear-gradient(90deg, #007AFF, #5856D6);
  border-radius: 8rpx;
}

.period-value.highlight {
  color: #007AFF;
  font-weight: 600;
}

.achievements {
  background: rgba(30, 35, 60, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.achievements-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 30rpx;
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.badge-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  text-align: center;
  padding: 30rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s;
}

.badge-item.locked {
  opacity: 0.4;
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.3));
}

.badge-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.badge-status {
  font-size: 20rpx;
  color: #007AFF;
}

.poster-section {
  background: linear-gradient(135deg, rgba(30, 35, 60, 0.8) 0%, rgba(40, 45, 75, 0.6) 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.btn-poster {
  background: linear-gradient(135deg, #007AFF, #5856D6);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 122, 255, 0.4);
  transition: all 0.3s;
}

.btn-poster:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}
