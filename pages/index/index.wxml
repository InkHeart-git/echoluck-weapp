<!-- 许愿首页 - iOS深色星空风格 -->
<view class="container">
  <!-- 星空背景 -->
  <view class="starfield-container">
    <!-- 静态星星 - 小 -->
    <view class="star-bg" style="top: 10%; left: 15%; width: 2rpx; height: 2rpx; opacity: 0.6; animation: twinkle 3s infinite;"></view>
    <view class="star-bg" style="top: 20%; left: 80%; width: 2rpx; height: 2rpx; opacity: 0.4; animation: twinkle 2.5s infinite 0.5s;"></view>
    <view class="star-bg" style="top: 35%; left: 25%; width: 2rpx; height: 2rpx; opacity: 0.5; animation: twinkle 3.5s infinite 1s;"></view>
    <view class="star-bg" style="top: 45%; left: 70%; width: 2rpx; height: 2rpx; opacity: 0.7; animation: twinkle 2.8s infinite 0.3s;"></view>
    <view class="star-bg" style="top: 55%; left: 10%; width: 2rpx; height: 2rpx; opacity: 0.4; animation: twinkle 4s infinite 0.8s;"></view>
    <view class="star-bg" style="top: 65%; left: 85%; width: 2rpx; height: 2rpx; opacity: 0.6; animation: twinkle 3.2s infinite 0.2s;"></view>
    <view class="star-bg" style="top: 75%; left: 40%; width: 2rpx; height: 2rpx; opacity: 0.5; animation: twinkle 2.6s infinite 1.2s;"></view>
    <view class="star-bg" style="top: 85%; left: 60%; width: 2rpx; height: 2rpx; opacity: 0.7; animation: twinkle 3.8s infinite 0.6s;"></view>
    <view class="star-bg" style="top: 15%; left: 50%; width: 2rpx; height: 2rpx; opacity: 0.4; animation: twinkle 2.4s infinite 1.5s;"></view>
    <view class="star-bg" style="top: 30%; left: 90%; width: 2rpx; height: 2rpx; opacity: 0.6; animation: twinkle 3.3s infinite 0.4s;"></view>
    
    <!-- 中等星星 -->
    <view class="star-bg" style="top: 12%; left: 35%; width: 4rpx; height: 4rpx; opacity: 0.7; animation: twinkle 2.5s infinite;"></view>
    <view class="star-bg" style="top: 28%; left: 60%; width: 4rpx; height: 4rpx; opacity: 0.5; animation: twinkle 3s infinite 0.7s;"></view>
    <view class="star-bg" style="top: 48%; left: 20%; width: 4rpx; height: 4rpx; opacity: 0.8; animation: twinkle 2.2s infinite 0.3s;"></view>
    <view class="star-bg" style="top: 68%; left: 75%; width: 4rpx; height: 4rpx; opacity: 0.6; animation: twinkle 2.8s infinite 1.1s;"></view>
    <view class="star-bg" style="top: 82%; left: 45%; width: 4rpx; height: 4rpx; opacity: 0.7; animation: twinkle 3.5s infinite 0.5s;"></view>
    
    <!-- 大星星（带光晕） -->
    <view class="star-bg" style="top: 8%; left: 65%; width: 6rpx; height: 6rpx; opacity: 0.9; box-shadow: 0 0 12rpx rgba(255,255,255,0.9), 0 0 20rpx rgba(0,122,255,0.3); animation: twinkle 2s infinite;"></view>
    <view class="star-bg" style="top: 38%; left: 5%; width: 6rpx; height: 6rpx; opacity: 0.8; box-shadow: 0 0 12rpx rgba(255,255,255,0.9), 0 0 20rpx rgba(88,86,214,0.3); animation: twinkle 2.5s infinite 0.5s;"></view>
    <view class="star-bg" style="top: 58%; left: 95%; width: 6rpx; height: 6rpx; opacity: 0.9; box-shadow: 0 0 12rpx rgba(255,255,255,0.9), 0 0 20rpx rgba(0,122,255,0.3); animation: twinkle 2.3s infinite 0.8s;"></view>
    <view class="star-bg" style="top: 88%; left: 30%; width: 6rpx; height: 6rpx; opacity: 0.7; box-shadow: 0 0 12rpx rgba(255,255,255,0.9), 0 0 20rpx rgba(88,86,214,0.3); animation: twinkle 2.7s infinite 0.2s;"></view>
  </view>

  <view class="header">
    <view class="logo"><image src="/images/app-icon-clean.png" mode="aspectFit" class="logo-image"></image></view>
    <view class="title">我的愿望打卡本</view>
    <view class="subtitle">记录目标，每日进阶</view>
  </view>

  <!-- 快捷许愿区 -->
  <view class="preset-grid">
    <view class="preset-chip {{selectedPreset === 0 ? 'active' : ''}}" bindtap="selectPreset" data-index="0" data-text="今晚做个好梦" data-days="1" data-difficulty="easy">
      <text class="preset-icon">🌙</text>
      <text class="preset-text">今晚做个好梦</text>
    </view>
    <view class="preset-chip {{selectedPreset === 1 ? 'active' : ''}}" bindtap="selectPreset" data-index="1" data-text="明天心情超棒" data-days="1" data-difficulty="easy">
      <text class="preset-icon">🌈</text>
      <text class="preset-text">明天心情超棒</text>
    </view>
    <view class="preset-chip {{selectedPreset === 2 ? 'active' : ''}}" bindtap="selectPreset" data-index="2" data-text="本周水逆退散" data-days="7" data-difficulty="medium">
      <text class="preset-icon">🍀</text>
      <text class="preset-text">本周水逆退散</text>
    </view>
    <view class="preset-chip {{selectedPreset === 3 ? 'active' : ''}}" bindtap="selectPreset" data-index="3" data-text="考试/面试顺利" data-days="7" data-difficulty="medium">
      <text class="preset-icon">💼</text>
      <text class="preset-text">考试/面试顺利</text>
    </view>
  </view>

  <!-- 难度选择 -->
  <view class="section-label">目标难度</view>
  <view class="difficulty-tabs">
    <view class="difficulty-tab easy {{difficulty === 'easy' ? 'active' : ''}}" bindtap="selectDifficulty" data-level="easy">
      <view class="difficulty-label">🌱 简单</view>
      <view class="difficulty-range">50-200pt · 1-3天</view>
    </view>
    <view class="difficulty-tab medium {{difficulty === 'medium' ? 'active' : ''}}" bindtap="selectDifficulty" data-level="medium">
      <view class="difficulty-label">🌿 中等</view>
      <view class="difficulty-range">300-800pt · 7-14天</view>
    </view>
    <view class="difficulty-tab hard {{difficulty === 'hard' ? 'active' : ''}}" bindtap="selectDifficulty" data-level="hard">
      <view class="difficulty-label">🌳 困难</view>
      <view class="difficulty-range">1000-5000pt · 30-90天</view>
    </view>
  </view>

  <!-- 自定义目标 -->
  <view class="section-label">写下你的目标</view>
  <textarea 
    class="wish-input" 
    placeholder="写下你的小目标..."
    placeholder-style="color: rgba(255,255,255,0.4)"
    value="{{wishText}}"
    bindinput="onWishInput"
    maxlength="100"
  />

  <!-- 实现周期 -->
  <view class="section-label">实现周期</view>
  <picker mode="selector" range="{{dayOptions}}" range-key="text" value="{{dayIndex}}" bindchange="onDayChange">
    <view class="picker">
      <text>{{dayOptions[dayIndex].text}}</text>
      <text class="picker-arrow">▼</text>
    </view>
  </picker>

  <!-- 生成按钮 -->
  <button class="btn btn-primary" bindtap="startValuation">
    <text>创建打卡记录</text>
  </button>
</view>
