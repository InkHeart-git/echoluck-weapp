<!-- pages/dashboard/dashboard.wxml -->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{totalPoints}}</view>
      <view class="stat-label">总积分</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{completedWishes}}</view>
      <view class="stat-label">已完成</view>
    </view>
    <view class="stat-item" bindtap="onCheckIn">
      <view class="stat-value {{todayCheckedIn ? 'checked' : ''}}">{{streak.current}}</view>
      <view class="stat-label">{{todayCheckedIn ? '已打卡' : '点击打卡'}}</view>
      <view class="streak-flame" wx:if="{{streak.current > 0}}">🔥</view>
    </view>
  </view>

  <!-- 连续打卡提示 -->
  <view class="streak-banner" wx:if="{{streak.current >= 3}}">
    <text class="streak-icon">🔥</text>
    <text>连续 {{streak.current}} 天打卡！加成 +{{streakBonus}}%</text>
  </view>

  <!-- 胶囊列表 -->
  <view class="section-title">我的运气胶囊 <text class="count">({{capsules.length}})</text></view>

  <view class="capsule-list" wx:if="{{capsules.length > 0}}">
    <view 
      class="capsule-item {{item.completed ? 'completed' : ''}} {{item.isExpired ? 'expired' : ''}}" 
      wx:for="{{capsules}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onCapsuleTap"
    >
      <view class="capsule-header">
        <view class="capsule-status {{item.completed ? 'done' : item.isExpired ? 'expired' : 'active'}}">
          {{item.completed ? '已完成' : item.isExpired ? '已过期' : '进行中'}}
        </view>
        <view class="capsule-points">{{item.points}}pt</view>
      </view>

      <view class="capsule-wish">{{item.wish}}</view>

      <view class="capsule-meta">
        <text class="capsule-date">创建于 {{item.createdAt}}</text>
        <text class="capsule-days" wx:if="{{!item.completed && !item.isExpired}}">剩余 {{item.remainingDays}} 天</text>
      </view>

      <!-- 进度条 -->
      <view class="progress-bar" wx:if="{{!item.completed && !item.isExpired}}">
        <view class="progress-fill" style="width: {{item.progress}}%"></view>
      </view>

      <!-- 操作按钮 -->
      <view class="capsule-actions" catchtap="stopPropagation">
        <button 
          class="btn-log" 
          wx:if="{{!item.completed && !item.isExpired}}"
          data-id="{{item.id}}"
          catchtap="onLogToday"
        >
          📝 记录今日
        </button>
        
        <view class="progress-info" wx:if="{{!item.completed && !item.isExpired}}">
          <text class="current-points">{{item.currentPoints || 0}}/{{item.points}} pt</text>
        </view>
        
        <button 
          class="btn-delete" 
          data-id="{{item.id}}"
          catchtap="onDeleteCapsule"
        >
          删除
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{capsules.length === 0 && !loading}}">
    <view class="empty-icon">💊</view>
    <view class="empty-title">还没有打卡记录</view>
    <view class="empty-desc">写下你的小目标，开始记录吧</view>
    <button class="btn-primary" bindtap="onCreateNew">去记录</button>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
