<!-- pages/daily-log/daily-log.wxml -->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step {{currentStep >= 0 ? 'active' : ''}} {{currentStep > 0 ? 'completed' : ''}}">
      <text class="step-num">1</text>
      <text class="step-text">类型</text>
    </view>
    <view class="step-line {{currentStep >= 1 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 1 ? 'active' : ''}} {{currentStep > 1 ? 'completed' : ''}}">
      <text class="step-num">2</text>
      <text class="step-text">行动</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}} {{currentStep > 2 ? 'completed' : ''}}">
      <text class="step-num">3</text>
      <text class="step-text">描述</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <text class="step-num">4</text>
      <text class="step-text">评估</text>
    </view>
  </view>

  <!-- 胶囊信息卡片 -->
  <view class="capsule-card">
    <view class="capsule-wish">{{capsule.wish}}</view>
    <view class="capsule-progress">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{capsule.progress || 0}}%"></view>
      </view>
      <view class="progress-text">{{capsule.currentPoints || 0}}/{{capsule.points}} pt ({{capsule.progress || 0}}%)</view>
    </view>
  </view>

  <!-- 步骤0: 选择行动类型 -->
  <view class="step-content" wx:if="{{currentStep === 0}}">
    <view class="section-title">今天你想完成什么样的行动？</view>
    <view class="section-subtitle">选择类型来积累积分</view>
    
    <view class="task-type-grid">
      <view
        class="task-type-card {{selectedTaskType === item.id ? 'selected' : ''}}"
        wx:for="{{taskTypes}}"
        wx:key="id"
        bindtap="selectTaskType"
        data-type="{{item.id}}"
        style="border-color: {{selectedTaskType === item.id ? item.color : 'transparent'}}; background: linear-gradient(135deg, {{item.color}}15, {{item.color}}05)"
      >
        <view class="task-icon-bg" style="background: {{item.color}}"><text class="task-icon">{{item.icon}}</text></view>
        <view class="task-info">
          <text class="task-name">{{item.name}}</text>
          <text class="task-desc">{{item.description}}</text>
        </view>
        <view wx:if="{{selectedTaskType === item.id}}" class="selected-mark">✓</view>
      </view>
    </view>
  </view>

  <!-- 步骤1: 选择具体行动 -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <view class="section-title">选择具体行动</view>
    
    <view class="selected-type-banner" wx:if="{{taskType}}" style="background: linear-gradient(90deg, {{taskType.color}}20, {{taskType.color}}05)">
      <text class="banner-icon">{{taskType.icon}}</text>
      <text class="banner-text">{{taskType.name}}</text>
    </view>

    <!-- 已选行动展示 -->
    <view class="selected-actions-bar" wx:if="{{selectedActions.length > 0}}">
      <view class="selected-tag" wx:for="{{selectedActions}}" wx:key="id">
        <text>{{item.icon}} {{item.name}}</text>
        <view class="remove-btn" bindtap="removeAction" data-id="{{item.id}}">×</view>
      </view>
    </view>

    <view class="action-grid">
      <view
        class="action-card {{item.selected ? 'selected' : ''}}"
        wx:for="{{taskActions}}"
        wx:key="id"
        bindtap="selectAction"
        data-id="{{item.id}}"
      >
        <view class="action-icon">{{item.icon}}</view>
        <view class="action-info">
          <text class="action-name">{{item.name}}</text>
          <text class="action-desc">{{item.desc}}</text>
        </view>
        <view wx:if="{{item.selected}}" class="selected-mark">✓</view>
      </view>

      <!-- 自定义行动 -->
      <view class="action-card custom {{showCustomInput ? 'expanded' : ''}}" bindtap="toggleCustomInput">
        <view class="action-icon">✏️</view>
        <view class="action-info">
          <text class="action-name">自定义行动</text>
          <text class="action-desc">{{showCustomInput ? '点击收起' : '添加其他行动'}}</text>
        </view>
      </view>
    </view>

    <!-- 自定义输入框 -->
    <view class="custom-input-section" wx:if="{{showCustomInput}}">
      <view class="input-wrapper">
        <input 
          class="custom-input" 
          placeholder="请输入自定义行动..."
          value="{{customAction}}"
          bindinput="onCustomActionInput"
        />
        <view class="add-btn" bindtap="addCustomAction">添加</view>
      </view>
    </view>
  </view>

  <!-- 步骤2: 补充描述 -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="section-title">补充描述</view>
    <view class="section-subtitle">选填：记录更多细节</view>

    <view class="input-section">
      <view class="input-wrapper">
        <textarea
          class="description-input"
          placeholder="可以补充更多细节，记录你的感受和收获..."
          value="{{description}}"
          bindinput="onDescriptionInput"
          maxlength="200"
        />
      </view>
      <view class="char-count">{{description.length}}/200</view>
    </view>

    <!-- 快捷标签 -->
    <view class="quick-tags">
      <view class="tag-label">快捷添加：</view>
      <view class="tags-list">
        <view 
          class="tag-item" 
          wx:for="{{quickTags}}" 
          wx:key="*this"
          bindtap="addQuickTag"
          data-tag="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>
  </view>

  <!-- 步骤3: 回答问题 -->
  <view class="step-content" wx:if="{{currentStep === 3}}">
    <view class="section-title">评估您的今日行动</view>
    
    <view class="questions-list">
      <view class="question-item" wx:for="{{questions}}" wx:key="dimension">
        <view class="question-header">
          <text class="question-number">{{index + 1}}</text>
          <text class="question-text">{{item.question}}</text>
        </view>
        
        <view class="options-grid">
          <view
            class="option-card {{answers[item.dimension] === opt.value ? 'selected' : ''}}"
            wx:for="{{item.options}}"
            wx:for-item="opt"
            wx:key="value"
            data-dimension="{{item.dimension}}"
            data-option="{{opt.value}}"
            bindtap="selectAnswer"
          >
            <view class="option-icon" wx:if="{{opt.icon}}">{{opt.icon}}</view>
            <view class="option-text">{{opt.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 实时得分 -->
    <view class="score-preview" wx:if="{{todayScore > 0}}">
      <text class="score-label">预计获得</text>
      <text class="score-value">+{{todayScore}} pt</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button
      class="btn btn-secondary"
      wx:if="{{currentStep > 0}}"
      bindtap="prevStep"
    >
      上一步
    </button>
    
    <button
      class="btn btn-primary"
      bindtap="nextStep"
      disabled="{{!canProceed}}"
    >
      {{currentStep === 3 ? '提交' : '下一步'}}
    </button>
  </view>
</view>